  "description": "Deterministic offline renderer for canonical PR-Inspector next-action prompts and human handoffs.",
  "type": "module",
  "license": "UNLICENSED",
  "engines": {"node": ">=20.20.0"},
  "bin": {"pr-inspector-prompt-renderer": "dist/cli.js"},
