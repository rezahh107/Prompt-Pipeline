{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prompt-quality-execution-program.v1",
  "title": "Prompt Quality Migration Execution Program v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "program_id",
    "repository",
    "program_status",
    "implementation_authorized",
    "authoritative_activation_state",
    "activation_state",
    "effects",
    "authorities",
    "activation_obligations",
    "deliverables",
    "approved_architecture",
    "tasks"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "prompt-quality-execution-program.v1"
    },
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "const": "rezahh107/Prompt-Pipeline"
    },
    "program_status": {
      "enum": [
        "draft",
        "active",
        "retired"
      ]
    },
    "implementation_authorized": {
      "type": "boolean"
    },
    "authoritative_activation_state": {
      "enum": [
        "candidate_pending_merge",
        "active"
      ]
    },
    "activation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_state",
        "validation_state",
        "merge_state",
        "exact_main_state"
      ],
      "properties": {
        "implementation_state": {
          "enum": [
            "not_started",
            "implemented"
          ]
        },
        "validation_state": {
          "enum": [
            "pending_exact_head_ci",
            "validated_exact_head",
            "blocked"
          ]
        },
        "merge_state": {
          "enum": [
            "pending_owner_merge",
            "merged"
          ]
        },
        "exact_main_state": {
          "enum": [
            "pending",
            "verified"
          ]
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_credit",
        "migration_promotion_effect",
        "production_authority_effect",
        "release_readiness_claim",
        "production_readiness_claim",
        "legacy_retirement_effect",
        "substantive_task_implementation"
      ],
      "properties": {
        "quality_credit": {
          "type": "boolean"
        },
        "migration_promotion_effect": {
          "enum": [
            "none",
            "candidate",
            "promoted"
          ]
        },
        "production_authority_effect": {
          "enum": [
            "none",
            "legacy_authoritative",
            "new_shadow",
            "new_authoritative_legacy_rollback",
            "new_only"
          ]
        },
        "release_readiness_claim": {
          "type": "boolean"
        },
        "production_readiness_claim": {
          "type": "boolean"
        },
        "legacy_retirement_effect": {
          "enum": [
            "none",
            "partial",
            "complete"
          ]
        },
        "substantive_task_implementation": {
          "enum": [
            "none",
            "partial",
            "complete"
          ]
        }
      }
    },
    "authorities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutable_current_status_authority",
        "durable_execution_plan_authority",
        "machine_readable_execution_program_authority",
        "append_only_impact_history",
        "lifecycle_evidence_authority",
        "diagnostic_registry_authority",
        "current_scope_selector"
      ],
      "properties": {
        "mutable_current_status_authority": {
          "type": "string",
          "minLength": 1
        },
        "durable_execution_plan_authority": {
          "type": "string",
          "minLength": 1
        },
        "machine_readable_execution_program_authority": {
          "type": "string",
          "minLength": 1
        },
        "append_only_impact_history": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_evidence_authority": {
          "type": "string",
          "minLength": 1
        },
        "diagnostic_registry_authority": {
          "type": "string",
          "minLength": 1
        },
        "current_scope_selector": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "activation_obligations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "obligation_id",
          "title",
          "required_paths"
        ],
        "properties": {
          "obligation_id": {
            "type": "string",
            "pattern": "^ACT-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "required_paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "deliverable_id",
          "kind",
          "substantive_quality_effect"
        ],
        "properties": {
          "deliverable_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "substantive_quality_effect": {
            "type": "boolean"
          }
        }
      }
    },
    "approved_architecture": {
      "type": "object",
      "minProperties": 11
    },
    "tasks": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "depends_on",
          "purpose",
          "registration_state",
          "authorization_state",
          "execution_state",
          "implementation_state",
          "completion_state",
          "blocking_state"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^PPQR-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "purpose": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "preferred_domain": {
            "type": "string",
            "minLength": 1
          },
          "preferred_candidates": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "preferred_subtype": {
            "type": "string",
            "minLength": 1
          },
          "registration_state": {
            "enum": [
              "registered",
              "unregistered"
            ]
          },
          "authorization_state": {
            "enum": [
              "authorized",
              "unauthorized"
            ]
          },
          "execution_state": {
            "enum": [
              "eligible",
              "dependency_blocked",
              "policy_blocked"
            ]
          },
          "implementation_state": {
            "enum": [
              "not_started",
              "implemented"
            ]
          },
          "completion_state": {
            "enum": [
              "incomplete",
              "complete"
            ]
          },
          "blocking_state": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "blocked",
              "blocking_reasons"
            ],
            "properties": {
              "blocked": {
                "type": "boolean"
              },
              "blocking_reasons": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
