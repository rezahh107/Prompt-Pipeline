{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prompt-quality-execution-program.v1",
  "title": "Prompt Quality Migration Execution Program v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "program_id",
    "repository",
    "program_status",
    "implementation_authorized",
    "authoritative_activation_state",
    "activation_state",
    "effects",
    "authorities",
    "activation_obligations",
    "deliverables",
    "approved_architecture",
    "tasks"
  ],
  "$defs": {
    "non_empty_unique_strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "prompt-quality-execution-program.v1"
    },
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "const": "rezahh107/Prompt-Pipeline"
    },
    "program_status": {
      "enum": [
        "draft",
        "active",
        "retired"
      ]
    },
    "implementation_authorized": {
      "type": "boolean"
    },
    "authoritative_activation_state": {
      "enum": [
        "candidate_pending_merge",
        "active"
      ]
    },
    "activation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_state",
        "validation_state",
        "merge_state",
        "exact_main_state"
      ],
      "properties": {
        "implementation_state": {
          "enum": [
            "not_started",
            "implemented"
          ]
        },
        "validation_state": {
          "enum": [
            "pending_exact_head_ci",
            "validated_exact_head",
            "blocked"
          ]
        },
        "merge_state": {
          "enum": [
            "pending_owner_merge",
            "merged"
          ]
        },
        "exact_main_state": {
          "enum": [
            "pending",
            "verified"
          ]
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_credit",
        "migration_promotion_effect",
        "production_authority_effect",
        "release_readiness_claim",
        "production_readiness_claim",
        "legacy_retirement_effect",
        "substantive_task_implementation"
      ],
      "properties": {
        "quality_credit": {
          "type": "boolean"
        },
        "migration_promotion_effect": {
          "enum": [
            "none",
            "candidate",
            "promoted"
          ]
        },
        "production_authority_effect": {
          "enum": [
            "none",
            "legacy_authoritative",
            "new_shadow",
            "new_authoritative_legacy_rollback",
            "new_only"
          ]
        },
        "release_readiness_claim": {
          "type": "boolean"
        },
        "production_readiness_claim": {
          "type": "boolean"
        },
        "legacy_retirement_effect": {
          "enum": [
            "none",
            "partial",
            "complete"
          ]
        },
        "substantive_task_implementation": {
          "enum": [
            "none",
            "partial",
            "complete"
          ]
        }
      }
    },
    "authorities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutable_current_status_authority",
        "durable_execution_plan_authority",
        "machine_readable_execution_program_authority",
        "append_only_impact_history",
        "lifecycle_evidence_authority",
        "diagnostic_registry_authority",
        "current_scope_selector"
      ],
      "properties": {
        "mutable_current_status_authority": {
          "type": "string",
          "minLength": 1
        },
        "durable_execution_plan_authority": {
          "type": "string",
          "minLength": 1
        },
        "machine_readable_execution_program_authority": {
          "type": "string",
          "minLength": 1
        },
        "append_only_impact_history": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_evidence_authority": {
          "type": "string",
          "minLength": 1
        },
        "diagnostic_registry_authority": {
          "type": "string",
          "minLength": 1
        },
        "current_scope_selector": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "activation_obligations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "obligation_id",
          "title",
          "required_paths"
        ],
        "properties": {
          "obligation_id": {
            "type": "string",
            "pattern": "^ACT-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "required_paths": {
            "$ref": "#/$defs/non_empty_unique_strings"
          }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "deliverable_id",
          "kind",
          "substantive_quality_effect"
        ],
        "properties": {
          "deliverable_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "substantive_quality_effect": {
            "type": "boolean"
          }
        }
      }
    },
    "approved_architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_first_hybrid_evaluation",
        "domain_contracts",
        "executable_rules",
        "thin_templates",
        "domain_quality_packs",
        "risk_tiered_evaluation",
        "model_capability_profiles",
        "semantic_evaluation",
        "selective_shadow",
        "migration_authority",
        "complexity_budgets",
        "repository_implementation_assurance_lite"
      ],
      "properties": {
        "quality_first_hybrid_evaluation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "repository_authority",
            "external_tool_boundary",
            "preferred_harness"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "repository_authority": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "external_tool_boundary": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "preferred_harness": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "tool",
                "role",
                "authority",
                "version_pinning"
              ],
              "properties": {
                "tool": {
                  "const": "promptfoo"
                },
                "role": {
                  "const": "execution_only"
                },
                "authority": {
                  "const": "none"
                },
                "version_pinning": {
                  "const": "required"
                }
              }
            }
          }
        },
        "domain_contracts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "normative_shape",
            "instances",
            "required_semantics",
            "critical_input_silent_defaults"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "normative_shape": {
              "const": "JSON Schema"
            },
            "instances": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "required_semantics": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "critical_input_silent_defaults": {
              "const": "prohibited"
            }
          }
        },
        "executable_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "required_fields",
            "enforcement_chain",
            "prose_presence_counts_as_enforcement"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "required_fields": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "enforcement_chain": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "prose_presence_counts_as_enforcement": {
              "const": false
            }
          }
        },
        "thin_templates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "role",
            "prohibited_authorities",
            "preserve_existing_template_technology"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "role": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "prohibited_authorities": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "preserve_existing_template_technology": {
              "const": true
            }
          }
        },
        "domain_quality_packs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "default_corpus_layers",
            "conditional_layers",
            "calibration_required_before_blocking_semantic_evaluation"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "default_corpus_layers": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "conditional_layers": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "calibration_required_before_blocking_semantic_evaluation": {
              "const": true
            }
          }
        },
        "risk_tiered_evaluation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "classification_inputs",
            "tiers"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "classification_inputs": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "tiers": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "Tier_1_Basic",
                  "Tier_2_Standard",
                  "Tier_3_High_Risk",
                  "Tier_4_Critical"
                ]
              }
            }
          }
        },
        "model_capability_profiles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "model_name_alone_is_tested_identity",
            "required_identity_fields"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "model_name_alone_is_tested_identity": {
              "const": false
            },
            "required_identity_fields": {
              "$ref": "#/$defs/non_empty_unique_strings"
            }
          }
        },
        "semantic_evaluation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "initial_authority",
            "blocking_prerequisites",
            "single_undifferentiated_score_primary_authority",
            "multi_judge_panel_proves_independent_consensus"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "initial_authority": {
              "const": "non_authoritative_non_blocking"
            },
            "blocking_prerequisites": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "single_undifferentiated_score_primary_authority": {
              "const": false
            },
            "multi_judge_panel_proves_independent_consensus": {
              "const": false
            }
          }
        },
        "selective_shadow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "universal_shadow",
            "evidence_triggers"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "universal_shadow": {
              "const": false
            },
            "evidence_triggers": {
              "$ref": "#/$defs/non_empty_unique_strings"
            }
          }
        },
        "migration_authority": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "sole_transition_authority",
            "quality_delta_gate_role",
            "one_production_authoritative_path",
            "low_risk_lifecycle",
            "high_risk_lifecycle"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "sole_transition_authority": {
              "const": "Migration Promotion Gate"
            },
            "quality_delta_gate_role": {
              "const": "required_subgate"
            },
            "one_production_authoritative_path": {
              "const": true
            },
            "low_risk_lifecycle": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "high_risk_lifecycle": {
              "$ref": "#/$defs/non_empty_unique_strings"
            }
          }
        },
        "complexity_budgets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "universal_prompt_ir",
            "constraints"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "universal_prompt_ir": {
              "const": false
            },
            "constraints": {
              "$ref": "#/$defs/non_empty_unique_strings"
            }
          }
        },
        "repository_implementation_assurance_lite": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "role",
            "new_domain_required",
            "new_task_required",
            "profile_name",
            "selection_basis",
            "activation_mode",
            "simple_requests_default",
            "bundle_shape",
            "artifact_name",
            "required_sections",
            "structural_validation",
            "implementation_report_required_fields",
            "states",
            "target_repository_validator_required_for_initial_pilot",
            "downstream_independent_review",
            "initial_authority",
            "task_integration",
            "promotion_requires",
            "not_claimed"
          ],
          "properties": {
            "status": {
              "const": "registered_future_work"
            },
            "role": {
              "const": "cross_cutting_adaptive_profile"
            },
            "new_domain_required": {
              "const": false
            },
            "new_task_required": {
              "const": false
            },
            "profile_name": {
              "const": "assurance_lite"
            },
            "selection_basis": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "activation_mode": {
              "const": "adaptive"
            },
            "simple_requests_default": {
              "const": "disabled"
            },
            "bundle_shape": {
              "const": "implementation_prompt_plus_one_linked_assurance_artifact"
            },
            "artifact_name": {
              "const": "assurance-lite.yaml"
            },
            "required_sections": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "structural_validation": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "implementation_report_required_fields": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "states": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "declared",
                  "implemented",
                  "verified"
                ]
              }
            },
            "target_repository_validator_required_for_initial_pilot": {
              "const": false
            },
            "downstream_independent_review": {
              "const": "PR-Inspector"
            },
            "initial_authority": {
              "const": "non_authoritative_non_blocking"
            },
            "task_integration": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "PPQR-001",
                "PPQR-002",
                "PPQR-003",
                "PPQR-004",
                "PPQR-005",
                "PPQR-006",
                "PPQR-007",
                "PPQR-009",
                "PPQR-010",
                "PPQR-012",
                "PPQR-015"
              ],
              "properties": {
                "PPQR-001": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-002": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-003": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-004": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-005": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-006": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-007": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-009": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-010": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-012": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                },
                "PPQR-015": {
                  "$ref": "#/$defs/non_empty_unique_strings"
                }
              }
            },
            "promotion_requires": {
              "$ref": "#/$defs/non_empty_unique_strings"
            },
            "not_claimed": {
              "$ref": "#/$defs/non_empty_unique_strings"
            }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "depends_on",
          "purpose",
          "registration_state",
          "authorization_state",
          "execution_state",
          "implementation_state",
          "completion_state",
          "blocking_state"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^PPQR-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "purpose": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "preferred_domain": {
            "type": "string",
            "minLength": 1
          },
          "preferred_candidates": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "preferred_subtype": {
            "type": "string",
            "minLength": 1
          },
          "registration_state": {
            "enum": [
              "registered",
              "unregistered"
            ]
          },
          "authorization_state": {
            "enum": [
              "authorized",
              "unauthorized"
            ]
          },
          "execution_state": {
            "enum": [
              "eligible",
              "dependency_blocked",
              "policy_blocked"
            ]
          },
          "implementation_state": {
            "enum": [
              "not_started",
              "implemented"
            ]
          },
          "completion_state": {
            "enum": [
              "incomplete",
              "complete"
            ]
          },
          "blocking_state": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "blocked",
              "blocking_reasons"
            ],
            "properties": {
              "blocked": {
                "type": "boolean"
              },
              "blocking_reasons": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
