{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prompt-pipeline-progress-impact.v1",
  "title": "Prompt Pipeline Progress Impact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "impact_id",
    "impact_version",
    "impact_hash",
    "sequence_number",
    "previous_impact_id",
    "repository",
    "program_id",
    "task_id",
    "pull_request",
    "base_sha",
    "scope_revision",
    "exact_head_binding",
    "work_type",
    "changed_paths",
    "state_before",
    "state_after",
    "baseline_before",
    "baseline_after",
    "completed_obligation_ids",
    "remaining_obligation_ids",
    "closed_deliverable_ids",
    "quality_dimensions_improved",
    "quality_dimensions_regressed",
    "quality_delta",
    "zero_delta",
    "blocking_defect",
    "maintenance_reason",
    "next_task_id",
    "effects",
    "quality_evidence",
    "migration_gate_evidence",
    "legacy_retirement_evidence",
    "production_paths"
  ],
  "properties": {
    "schema_version": {"const": "prompt-pipeline-progress-impact.v1"},
    "impact_id": {"type": "string", "pattern": "^PROMPT-QUALITY-IMPACT-[0-9]{4}$"},
    "impact_version": {"const": 1},
    "impact_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "sequence_number": {"type": "integer", "minimum": 1},
    "previous_impact_id": {"type": ["string", "null"]},
    "repository": {"const": "rezahh107/Prompt-Pipeline"},
    "program_id": {"const": "PROMPT-QUALITY-MIGRATION-EXECUTION-PROGRAM"},
    "task_id": {"type": "string", "minLength": 1},
    "pull_request": {"type": ["integer", "null"], "minimum": 1},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "scope_revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "exact_head_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "head_sha"],
      "properties": {
        "mode": {"enum": ["ci_runtime_exact_head", "exact_commit"]},
        "head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "work_type": {"enum": ["program_activation", "governance_foundation", "architecture_foundation", "quality_content", "migration_promotion", "blocking_defect", "maintenance"]},
    "changed_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "state_before": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registration_state", "authorization_state", "execution_state", "implementation_state", "completion_state"],
      "properties": {
        "registration_state": {"enum": ["registered", "unregistered"]},
        "authorization_state": {"enum": ["authorized", "unauthorized"]},
        "execution_state": {"enum": ["eligible", "dependency_blocked", "policy_blocked"]},
        "implementation_state": {"enum": ["not_started", "implemented"]},
        "completion_state": {"enum": ["incomplete", "complete"]}
      }
    },
    "state_after": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registration_state", "authorization_state", "execution_state", "implementation_state", "completion_state"],
      "properties": {
        "registration_state": {"enum": ["registered", "unregistered"]},
        "authorization_state": {"enum": ["authorized", "unauthorized"]},
        "execution_state": {"enum": ["eligible", "dependency_blocked", "policy_blocked"]},
        "implementation_state": {"enum": ["not_started", "implemented"]},
        "completion_state": {"enum": ["incomplete", "complete"]}
      }
    },
    "baseline_before": {"type": "object"},
    "baseline_after": {"type": "object"},
    "completed_obligation_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "remaining_obligation_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "closed_deliverable_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "quality_dimensions_improved": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "quality_dimensions_regressed": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "quality_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_regressions", "known_gaps"],
      "properties": {
        "critical_regressions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "known_gaps": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "zero_delta": {"type": "boolean"},
    "blocking_defect": {"type": ["string", "null"]},
    "maintenance_reason": {"type": ["string", "null"]},
    "next_task_id": {"type": ["string", "null"]},
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quality_credit", "migration_promotion", "production_authority", "release_readiness", "production_readiness", "legacy_retirement"],
      "properties": {
        "quality_credit": {"type": "boolean"},
        "migration_promotion": {"enum": ["none", "candidate", "promoted"]},
        "production_authority": {"enum": ["none", "legacy_authoritative", "new_shadow", "new_authoritative_legacy_rollback", "new_only"]},
        "release_readiness": {"type": "boolean"},
        "production_readiness": {"type": "boolean"},
        "legacy_retirement": {"enum": ["none", "partial", "complete"]}
      }
    },
    "quality_evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "migration_gate_evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "legacy_retirement_evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "production_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path_id", "authoritative"],
        "properties": {
          "path_id": {"type": "string", "minLength": 1},
          "authoritative": {"type": "boolean"}
        }
      }
    }
  }
}
