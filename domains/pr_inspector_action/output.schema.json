{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/Prompt-Pipeline/domains/pr_inspector_action/output.schema.json",
  "title": "PR Inspector Action Renderer Output v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_required",
    "action_kind",
    "prompt_kind",
    "recipient",
    "may_modify_code",
    "technical_status",
    "approval_requirement",
    "review_validity",
    "rendered_prompt",
    "rendered_prompt_sha256",
    "canonical_input_sha256",
    "generator",
    "human_review",
    "risk_metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "pr_inspector_action_output.v1"
    },
    "prompt_required": {
      "type": "boolean"
    },
    "action_kind": {
      "enum": [
        "merge_now",
        "owner_confirmation",
        "human_technical_review",
        "specialist_review",
        "repair",
        "verify",
        "repair_and_verify",
        "rerun_review",
        "blocked_internal_error"
      ]
    },
    "prompt_kind": {
      "enum": [
        null,
        "implementer_repair_prompt",
        "verification_prompt",
        "fresh_review_prompt",
        "human_review_handoff",
        "specialist_review_handoff"
      ]
    },
    "recipient": {
      "enum": [
        "none",
        "project_owner",
        "implementer_model",
        "reviewer_model",
        "human_technical_reviewer",
        "security_or_domain_specialist"
      ]
    },
    "may_modify_code": {
      "type": "boolean"
    },
    "technical_status": {
      "enum": [
        "GREEN_TECHNICALLY_READY",
        "YELLOW_CHANGES_OR_VERIFICATION_REQUIRED",
        "RED_DO_NOT_MERGE"
      ]
    },
    "approval_requirement": {
      "enum": [
        "NO_ADDITIONAL_TECHNICAL_APPROVAL",
        "PROJECT_OWNER_CONFIRMATION",
        "HUMAN_TECHNICAL_REVIEW_REQUIRED",
        "SECURITY_OR_DOMAIN_SPECIALIST_REQUIRED"
      ]
    },
    "review_validity": {
      "enum": [
        "CURRENT",
        "STALE",
        "UNKNOWN"
      ]
    },
    "rendered_prompt": {
      "type": [
        "string",
        "null"
      ]
    },
    "rendered_prompt_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "canonical_input_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "package_version",
        "prompt_pipeline_version",
        "source_commit_sha",
        "source_commit_verified",
        "source_identity_source",
        "dirty",
        "domain",
        "route_identity",
        "contract_version",
        "template_identity",
        "template_sha256",
        "input_schema_identity",
        "input_schema_sha256",
        "output_schema_identity",
        "output_schema_sha256",
        "policy_hashes",
        "checks_executed"
      ],
      "properties": {
        "package_name": {
          "const": "@rezahh107/pr-inspector-prompt-renderer"
        },
        "package_version": {
          "type": "string"
        },
        "prompt_pipeline_version": {
          "type": "string"
        },
        "source_commit_sha": {
          "type": "string",
          "pattern": "^(UNKNOWN|[0-9a-f]{40})$"
        },
        "source_commit_verified": {
          "type": "boolean"
        },
        "source_identity_source": {
          "enum": [
            "git",
            "build_context",
            "unknown"
          ]
        },
        "dirty": {
          "type": "boolean"
        },
        "domain": {
          "const": "pr_inspector_action"
        },
        "route_identity": {
          "type": "string"
        },
        "contract_version": {
          "const": "pr_inspector_action.v1"
        },
        "template_identity": {
          "type": "string"
        },
        "template_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "input_schema_identity": {
          "const": "pr_inspector_action.v1"
        },
        "input_schema_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "output_schema_identity": {
          "const": "pr_inspector_action_output.v1"
        },
        "output_schema_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "policy_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "checks_executed": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "approval_satisfied",
        "boundary"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "approval_satisfied": {
          "const": false
        },
        "boundary": {
          "type": "string"
        }
      }
    },
    "risk_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "technical_status",
        "sensitive_domains"
      ],
      "properties": {
        "technical_status": {
          "enum": [
            "GREEN_TECHNICALLY_READY",
            "YELLOW_CHANGES_OR_VERIFICATION_REQUIRED",
            "RED_DO_NOT_MERGE"
          ]
        },
        "sensitive_domains": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "AUTHENTICATION",
              "AUTHORIZATION",
              "PAYMENTS",
              "PERSONAL_DATA",
              "REGULATED_DATA",
              "CREDENTIAL_ACCESS",
              "CRYPTOGRAPHY",
              "DESTRUCTIVE_CHANGE",
              "DATABASE_MIGRATION",
              "PRODUCTION_INFRASTRUCTURE",
              "BACKUP_RECOVERY",
              "PUBLIC_API_COMPATIBILITY",
              "COMPLEX_CONCURRENCY",
              "SECURITY_BOUNDARY",
              "SUPPLY_CHAIN",
              "SAFETY_CRITICAL"
            ]
          }
        }
      }
    }
  }
}
