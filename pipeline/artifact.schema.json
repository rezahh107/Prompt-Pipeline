{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PEaC Prompt Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prompt_id",
    "generated_at",
    "domain",
    "execution_mode",
    "provenance",
    "policies_applied",
    "validation",
    "risk_level",
    "requires_human_review",
    "rendered_prompt"
  ],
  "properties": {
    "prompt_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "domain": { "type": "string" },
    "subtype": { "type": ["string", "null"] },
    "execution_mode": { "type": "string", "enum": ["interactive", "batch", "ci", "agent"] },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_request", "routing_method", "routing_confidence", "template_used", "template_version", "inputs_provided", "inputs_inferred", "inputs_defaulted"],
      "properties": {
        "user_request": { "type": "string" },
        "case_file": { "type": ["string", "null"] },
        "routing_method": { "type": "string" },
        "routing_confidence": { "type": "number" },
        "template_used": { "type": "string" },
        "template_version": { "type": "string" },
        "inputs_provided": { "type": "array", "items": { "type": "string" } },
        "inputs_inferred": { "type": "array", "items": { "type": "string" } },
        "inputs_defaulted": { "type": "array", "items": { "type": "string" } }
      }
    },
    "policies_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_ref", "triggered_by"],
        "properties": {
          "id": { "type": "string" },
          "source_ref": { "type": "string" },
          "source_hash": { "type": ["string", "null"] },
          "triggered_by": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "warnings", "errors", "checks_run"],
      "properties": {
        "passed": { "type": "boolean" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "errors": { "type": "array", "items": { "type": "string" } },
        "checks_run": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "requires_human_review": { "type": "boolean" },
    "review_reason": { "type": ["string", "null"] },
    "rendered_prompt": { "type": "string" }
  }
}
