{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prompt Pipeline Intake",
  "type": "object",
  "additionalProperties": false,
  "required": ["request", "desired_output", "strictness", "target_environment"],
  "allOf": [
    {
      "if": {
        "properties": { "strictness": { "const": "production-grade" } },
        "required": ["strictness"]
      },
      "then": {
        "required": ["success_criteria", "failure_modes", "eval_suite"],
        "properties": {
          "success_criteria": { "minItems": 1 },
          "failure_modes": { "minItems": 1 },
          "eval_suite": { "minItems": 1 }
        }
      }
    }
  ],
  "properties": {
    "request": { "type": "string", "minLength": 3 },
    "desired_output": { "type": "string", "minLength": 3 },
    "target_environment": {
      "type": "string",
      "enum": ["ChatGPT", "ChatGPT Project", "OpenAI API", "Codex", "Claude", "Gemini", "Local", "unspecified"]
    },
    "strictness": {
      "type": "string",
      "enum": ["quick", "precise", "production-grade"]
    },
    "output_language": {
      "type": "string",
      "description": "Deprecated legacy intake field retained for backward compatibility with non-prompt-generation fixtures. New prompt_generation artifacts use prompt_language, explanation_language, and target_output_language."
    },
    "model_profile": {
      "type": "string",
      "enum": ["gpt", "claude", "gemini", "local_small"]
    },
    "prompt_language": {
      "type": "string",
      "enum": ["English"],
      "default": "English"
    },
    "explanation_language": {
      "type": "string",
      "enum": ["Persian", "English"],
      "default": "Persian"
    },
    "target_output_language": {
      "type": "string",
      "enum": ["Persian", "English", "same_as_user"],
      "default": "Persian"
    },
    "available_sources": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "sensitive_or_high_risk": { "type": "boolean", "default": false },
    "uses_external_tools": { "type": "boolean", "default": false },
    "requires_current_information": { "type": "boolean", "default": false },
    "requires_structured_output": { "type": "boolean", "default": true },
    "domain_hint": {
      "type": ["string", "null"],
      "enum": ["prompt_generation", "prompt_audit", "prompt_refactor", "document_review", "repo_review", "coding_debugging", "image", "multimodal", "ai_workflow_design", "general", null]
    },
    "constraints": { "type": "array", "items": { "type": "string" }, "default": [] },
    "success_criteria": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "failure_modes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "eval_suite": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "human_review_required": { "type": "boolean", "default": false }
  }
}
