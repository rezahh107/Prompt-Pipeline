{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "peac-intake-v2",
  "title": "Prompt Pipeline Canonical Intake",
  "type": "object",
  "additionalProperties": false,
  "required": ["request", "desired_output", "strictness", "target_environment"],
  "allOf": [
    {
      "if": { "properties": { "strictness": { "const": "production-grade" } }, "required": ["strictness"] },
      "then": {
        "required": ["success_criteria", "failure_modes", "eval_suite"],
        "properties": {
          "success_criteria": { "type": "array", "minItems": 1 },
          "failure_modes": { "type": "array", "minItems": 1 },
          "eval_suite": { "type": "array", "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "context_policy": { "const": "minimal" } }, "required": ["context_policy"] },
      "then": { "properties": { "context_budget_tokens": { "maximum": 1200 } } }
    },
    {
      "if": { "properties": { "context_policy": { "const": "standard" } }, "required": ["context_policy"] },
      "then": { "properties": { "context_budget_tokens": { "maximum": 4000 } } }
    },
    {
      "if": { "properties": { "context_policy": { "const": "deep" } }, "required": ["context_policy"] },
      "then": { "properties": { "context_budget_tokens": { "maximum": 12000 } } }
    }
  ],
  "properties": {
    "request": { "type": "string", "minLength": 3 },
    "desired_output": { "type": "string", "minLength": 3 },
    "target_environment": { "type": "string", "enum": ["ChatGPT", "ChatGPT Project", "OpenAI API", "Codex", "Claude", "Gemini", "Local", "unspecified"] },
    "strictness": {
      "type": "string",
      "enum": ["quick", "precise", "production-grade"],
      "description": "production-grade is a legacy input label meaning static Prompt and metadata validation only; it does not claim target-model execution or behavioral assurance."
    },
    "output_language": { "type": "string", "description": "Deprecated legacy field retained for backward compatibility." },
    "model_profile": { "type": "string", "enum": ["gpt", "claude", "gemini", "local_small"] },
    "context_policy": { "type": "string", "enum": ["minimal", "standard", "deep"] },
    "context_budget_tokens": { "type": "integer", "minimum": 0, "maximum": 12000 },
    "context_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "purpose", "trust_level"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "trust_level": { "type": "string", "enum": ["user_provided", "official", "trusted", "untrusted", "unknown"] },
          "estimated_tokens": { "type": "integer", "minimum": 0 },
          "source_sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
        }
      },
      "default": []
    },
    "prompt_language": { "type": "string", "enum": ["English"], "default": "English" },
    "explanation_language": { "type": "string", "enum": ["Persian", "English"], "default": "Persian" },
    "target_output_language": { "type": "string", "enum": ["Persian", "English", "same_as_user"], "default": "Persian" },
    "available_sources": { "type": "array", "items": { "type": "string" }, "default": [] },
    "sensitive_or_high_risk": { "type": "boolean", "description": "Caller hint only; Runtime derives final risk." },
    "uses_external_tools": { "type": "boolean", "description": "Caller hint only; Runtime derives final risk." },
    "legal_medical_financial": { "type": "boolean", "description": "Caller hint only; Runtime also classifies request text." },
    "requires_current_information": { "type": "boolean", "description": "Caller hint only; Runtime derives final risk." },
    "exact_factual_claims": { "type": "boolean", "description": "Caller hint only; Runtime derives final risk." },
    "external_files": { "type": "boolean", "description": "Caller hint only; Runtime derives final risk." },
    "requires_structured_output": { "type": "boolean", "default": true },
    "requested_actions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "consumer_path": { "type": "string" },
    "model_interaction_mode": { "type": "string" },
    "potential_downstream_execution": { "type": "boolean" },
    "domain_hint": { "type": ["string", "null"], "enum": ["prompt_generation", "prompt_audit", "prompt_refactor", "document_review", "repo_review", "coding_debugging", "image", "multimodal", "ai_workflow_design", "general", null] },
    "constraints": { "type": "array", "items": { "type": "string" }, "default": [] },
    "success_criteria": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "failure_modes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "eval_suite": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "human_review_required": { "type": "boolean", "description": "Caller request for review; never proof that review occurred." }
  }
}
